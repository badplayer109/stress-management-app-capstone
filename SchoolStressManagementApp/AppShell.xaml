<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SchoolStressManagementApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SchoolStressManagementApp.Views"
    Title="SchoolStressManagementApp"
    Shell.FlyoutBehavior="Flyout">

    <FlyoutItem Title="Overview" Icon="stress_management_icon.png">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />
    </FlyoutItem>
    <FlyoutItem Title="Hydration Status" Icon="hydration_status_icon.png">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:HydrationStatusPage}"
            Route="HydrationStatusPage" />
    </FlyoutItem>
    <FlyoutItem Title="Sleep Status" Icon="sleep_status_icon.png">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:SleepStatusPage}"
            Route="SleepStatusPage" />
    </FlyoutItem>
    <FlyoutItem Title="Exercise Guide" Icon="exercise_guide_icon.png">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:ExerciseGuidePage}"
            Route="ExerciseGuidePage" />
    </FlyoutItem>
    

</Shell>
