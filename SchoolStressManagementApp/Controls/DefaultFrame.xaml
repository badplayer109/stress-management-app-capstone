<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolStressManagementApp.Controls.DefaultFrame">
    <Border StrokeShape="RoundRectangle 10" 
            BackgroundColor="{AppThemeBinding Light={StaticResource GeneralSurfaceLight}, Dark={StaticResource GeneralSurfaceDark}}"  Style="{StaticResource CardStyle}"
            Padding="10"
            Stroke="LightGray"
            StrokeThickness="1">
        <Border.Shadow>
            <Shadow Brush="Gray" Offset="10,10" Radius="20" Opacity="0.5" />
        </Border.Shadow>
            <FlexLayout >
                <Button Text="Back" Clicked="BackButton_Clicked" Padding="10" />
                <Label Text="Control Panel" Padding="10" />
            </FlexLayout>
    </Border>
</ContentView>
