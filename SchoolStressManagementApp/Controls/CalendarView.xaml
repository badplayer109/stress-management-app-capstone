<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SchoolStressManagementApp.ViewModels"
             xmlns:models="clr-namespace:SchoolStressManagementApp.Models"
             x:Class="SchoolStressManagementApp.Controls.CalendarView"
             x:DataType="viewModels:CalendarViewModel">
    <VerticalStackLayout>
        <Grid ColumnDefinitions="*,*,*" Padding="10,0">
            <Button ImageSource="right_arrow_button.png"
                    Rotation="180"
                    BackgroundColor="Transparent"
                    Command="{Binding PreviousMonthCommand}"
                    MinimumHeightRequest="0"
                    MinimumWidthRequest="0"
                    Padding="0"
                    HeightRequest="40"
                    WidthRequest="40" />
            <Label Grid.Column="1"
                   Text="{Binding MonthYear}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            <Button Grid.Column="2"
                    ImageSource="right_arrow_button.png"
                    BackgroundColor="Transparent"
                    Command="{Binding NextMonthCommand}"
                    MinimumHeightRequest="0"
                    MinimumWidthRequest="0"
                    Padding="0"
                    HeightRequest="40"
                    WidthRequest="40" />
        </Grid>

        <CollectionView ItemsSource="{Binding Weeks}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarWeek">
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Days}" HorizontalOptions="Center" Padding="4">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:CalendarDay">
                                <Button Text="{Binding Day}"
                                        Margin="3"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SelectDayCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                            <Style.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#B4B41E, Dark=Yellow}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>
