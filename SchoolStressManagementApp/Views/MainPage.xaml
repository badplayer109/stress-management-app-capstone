<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SchoolStressManagementApp.ViewModels"
             xmlns:models="clr-namespace:SchoolStressManagementApp.Models"
             xmlns:controls="clr-namespace:SchoolStressManagementApp.Controls"
             x:Class="SchoolStressManagementApp.Views.MainPage"
             x:DataType="viewModels:MainPageViewModel">
    <Grid>
        <Image
            Source="stress_management_background.png"
            Aspect="AspectFill"
            HorizontalOptions="Center"
            VerticalOptions="Center" />
        <ScrollView>
            <VerticalStackLayout Padding="30" Spacing="15">
                <Border Background="GhostWhite" Padding="10" StrokeThickness="4">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                    </Border.Shadow>
                    <Label Text="Stress Management Guide" FontSize="25" HorizontalOptions="Fill" />
                </Border>
                <Border Background="Honeydew" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="5">
                        <controls:CircularProgressBar 
                            Progress="{Binding StatusOverview}"
                            Size="220"
                            Thickness="8"
                            ProgressColor="Green"
                            ProgressLeftColor="LightGreen"
                            TextColor="DarkGreen" />
                        <Label Text="Status Overview" FontSize="30" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border HeightRequest="20" Background="GhostWhite" />
                
                <Border Background="AliceBlue" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                    </Border.Shadow>
                    <Grid RowDefinitions="20,20,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <controls:CircularProgressBar x:Name="HydrationStatusCircularBar"
                            Max="{Binding WaterIntakeOptimal}"
                            Min="{Binding WaterIntakeInit}"
                            Value="{Binding HydrationStatusToday.WaterIntake}"
                            Size="100"
                            Thickness="4"
                            ProgressColor="DeepSkyBlue"
                            ProgressLeftColor="LightSkyBlue"
                            TextColor="MidnightBlue"
                            Grid.RowSpan="3" />
                        <Label Grid.Row="0" Grid.Column="1"
                            Text="Hydration Status" />
                        <Label Grid.Row="1" Grid.Column="1"
                            Text="{Binding Value, Source={x:Reference HydrationStatusCircularBar}, StringFormat='Water drank: {0:F0} cups'}" />
                        <Button Grid.Row="2" Grid.Column="1" Padding="5" MinimumHeightRequest="0" HeightRequest="40"
                            Text="Open Hydration Page" Command="{Binding ToHydrationStatusPageCommand}" />
                    </Grid>
                </Border>

                <Border Background="LightGray" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                    </Border.Shadow>
                    <Grid RowDefinitions="20,20,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <controls:CircularProgressBar x:Name="SleepStatusCircularBar"
                            Max="{Binding SleepHoursOptimal}"
                            Min="{Binding SleepHoursInit}"
                            Value="{Binding SleepStatusToday.GetSleepHours}"
                            Size="100"
                            Thickness="4"
                            ProgressColor="DarkViolet"
                            ProgressLeftColor="DimGray"
                            TextColor="Purple"
                            Grid.RowSpan="3" />
                        <Label Grid.Row="0" Grid.Column="1"
                            Text="Sleep Status" />
                        <Label Grid.Row="1" Grid.Column="1"
                            Text="{Binding Value, Source={x:Reference SleepStatusCircularBar}, StringFormat='Time Slept: {0:F1} hours'}" />
                        <Button Grid.Row="2" Grid.Column="1" Padding="5" MinimumHeightRequest="0" HeightRequest="40"
                            Text="Open Sleep Page" Command="{Binding ToSleepStatusPageCommand}" />
                    </Grid>
                </Border>

                <Border Background="Beige" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                    </Border.Shadow>
                    <Grid RowDefinitions="20,20,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <controls:CircularProgressBar x:Name="ExerciseGuideCircularBar"
                            Progress="{Binding TotalExerciseProgress}"
                            Size="100"
                            Thickness="4"
                            ProgressColor="Gold"
                            ProgressLeftColor="PaleGoldenrod"
                            TextColor="Chocolate"
                            Grid.RowSpan="3" />
                        <Label Grid.Row="0" Grid.Column="1"
                            Text="Exercise Status"/>
                        <Label Grid.Row="1" Grid.Column="1"
                            Text="{Binding Progress, Source={x:Reference ExerciseGuideCircularBar}, StringFormat='Exercise Progress: {0:F2}%'}" />
                        <Button Grid.Row="2" Grid.Column="1" Padding="5" MinimumHeightRequest="0" HeightRequest="40" VerticalOptions="Start"
                            Text="Open Exercise Guide Page" Command="{Binding ToExerciseGuidePageCommand}" />
                    </Grid>
                </Border>
                <Border Background="Beige" Padding="0,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <Label Text="Exercise Plans Today" FontSize="20" HorizontalOptions="Center" Margin="5" />
                        <CollectionView ItemsSource="{Binding ExerciseStatusToday.RecordedPlans}"
                                        MinimumHeightRequest="75"
                                        MaximumHeightRequest="250">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ExercisePlanModel">
                                    <Border Stroke="PaleGoldenrod"
                                            StrokeThickness="4"
                                            Padding="10,5">
                                        <Grid RowDefinitions="*,*,*,*,*" ColumnDefinitions="*,*">
                                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Title}" Grid.ColumnSpan="2" />
                                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Id}" HorizontalOptions="End" Margin="10,0,0,5" />
                                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding TargetIntensity}" Grid.RowSpan="2" />
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding ProgressMinutes, StringFormat='Time Done: {0:%h\\h\\ %m\\m}', FallbackValue='Time Done: null'}" />
                                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TargetMinutes, StringFormat='Target Time: {0:%h\\h\\ %m\\m}', FallbackValue='Target Time: null'}" />
                                            <Label Grid.Row="3" Text="{Binding ExerciseLink, StringFormat='Link: {0}', FallbackValue='Link: None'}" Grid.ColumnSpan="2" />
                                            <Label Grid.Row="4" Text="{Binding Notes, StringFormat='Note: {0}', FallbackValue='Note: None'}" Grid.ColumnSpan="2" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Border Stroke="LightGray"
                                            StrokeThickness="4"
                                            Padding="5">
                                    <Label Text="No exercise plans scheduled." />
                                </Border>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Background="GhostWhite" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                    </Border.Shadow>
                    <Label Text="This app is in early development. Enjoy using these physical wellness journaling tools to make monitoring your physical wellness and stress levels more convenient. Notifications and stress management advice prompts are coming soon" Margin="10" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
