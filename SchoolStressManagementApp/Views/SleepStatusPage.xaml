<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SchoolStressManagementApp.ViewModels"
             xmlns:controls="clr-namespace:SchoolStressManagementApp.Controls"
             x:Class="SchoolStressManagementApp.Views.SleepStatusPage"
             Title="SleepStatusPage"
             x:DataType="viewModels:SleepStatusViewModel">
    <Grid>
        <Image
            Source="stress_management_background.png"
            Aspect="AspectFill"
            HorizontalOptions="Center"
            VerticalOptions="Center" />
        <ScrollView>
            <VerticalStackLayout Padding="30" Spacing="25">
                <controls:DefaultFrame />
                <controls:CircularProgressBar x:Name="SleepStatusCircularBar"
                    Max="{Binding SleepHoursOptimal}"
                    Min="{Binding SleepHoursInit}"
                    Value="{Binding SleepHours}"
                    Size="100"
                    Thickness="4"
                    ProgressColor="DarkViolet"
                    ProgressLeftColor="DimGray"
                    TextColor="Purple" />
                <Grid BackgroundColor="LightGray" Padding="10" RowDefinitions="20, 20, 40">
                    <Label Text="Sleep Status"/>
                    <Label Grid.Row="1"
                        Text="{Binding Value, Source={x:Reference SleepStatusCircularBar}, StringFormat='Hours Slept: {0:F1}'}"/>
                    <Slider Grid.Row="2" Value="{Binding SleepHours}" Maximum="24" Minimum="0" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>