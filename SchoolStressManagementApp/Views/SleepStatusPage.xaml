<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SchoolStressManagementApp.ViewModels"
             xmlns:controls="clr-namespace:SchoolStressManagementApp.Controls"
             xmlns:converters="clr-namespace:SchoolStressManagementApp.Converters"
             x:Class="SchoolStressManagementApp.Views.SleepStatusPage"
             Title="SleepStatusPage"
             x:DataType="viewModels:SleepStatusViewModel">
    <ContentPage.Resources>
        <converters:TimeSpanToAmPmConverter x:Key="TimeConverter"/>
    </ContentPage.Resources>
             
    <Grid>
        <Image
            Source="stress_management_background.png"
            Aspect="AspectFill"
            HorizontalOptions="Center"
            VerticalOptions="Center" />
        <ScrollView>
            <VerticalStackLayout Padding="15" Spacing="25">
                <controls:DefaultFrame />
                <Border Background="LightGray" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                </Border.Shadow>
                    <VerticalStackLayout>
                        <Label Text="Sleep Status Control Panel" FontSize="25" HorizontalOptions="Center" />
                        <Label Margin="0,25,0,10" FontSize="20"
                            Text="{Binding CurrentDay.Date, StringFormat='Record to: {0:MMMM dd, yyyy}', FallbackValue='Record to: Select a Date'}" />
                        <controls:CircularProgressBar x:Name="SleepStatusCircularBar"
                            Max="{Binding SleepHoursOptimal}"
                            Min="{Binding SleepHoursInit}"
                            Value="{Binding GetSleepHoursDraft}"
                            Size="180"
                            Thickness="10"
                            ProgressColor="DarkViolet"
                            ProgressLeftColor="DimGray"
                            TextColor="Purple"
                            Margin="0,25,0,0" />
                        <Grid RowDefinitions="*,*,*" ColumnDefinitions="*,*" Padding="5">
                            <Label Grid.Row="0" VerticalOptions="Center" Text="Hours of Sleep" />
                            <Label Grid.Row="0" Grid.Column="2"
                                Text="{Binding SleepHoursDraft, StringFormat='{}{0:%h}h {0:%m}m', FallbackValue='h m'}"/>

                            <Label Grid.Row="1" VerticalOptions="Center" Text="Bed Time" />
                            <TimePicker Grid.Row="1" Grid.Column="2" Time="{Binding BedTimeDraft}" />

                            <Label Grid.Row="2" VerticalOptions="Center" Text="Wake Up Time"/>
                            <TimePicker Grid.Row="2" Grid.Column="2" Time="{Binding WakeTimeDraft}" />
                        </Grid>
                        <Grid RowDefinitions="*,*" ColumnDefinitions="*,*">
                            <Button Grid.Row="0" Grid.Column="0"
                                Text="Clear Day" Command="{Binding ClearDayCommand}" />
                            <Button Grid.Row="0" Grid.Column="1"
                                Text="Record to Day" Command="{Binding RecordToDayCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                
                <Border Background="LightGray" Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Gray" Offset="5,5" Radius="10" Opacity="0.2" />
                </Border.Shadow>
                    <VerticalStackLayout>
                        <Border Stroke="DarkOrchid"
                                StrokeThickness="4"
                                Padding="5" Margin="0,10">
                            <Grid RowDefinitions="*,*,*,*,*" ColumnDefinitions="*,*" Margin="10,5">
                                <Label Grid.Row="0" Grid.ColumnSpan="2" HorizontalOptions="Center"
                                    Text="Day Sleep Status Information"
                                    FontSize="18" />
                                <Label Grid.Row="1" Grid.ColumnSpan="2" HorizontalOptions="Center" Margin="0,15,0,3"
                                    Text="{Binding CurrentDay.Date, StringFormat='{0:MMMM dd, yyyy}', FallbackValue='Select a Date'}" />
                                <Label Grid.Row="2" VerticalOptions="Center" HorizontalOptions="Center"
                                    Text="Hours of Sleep" />
                                <Label Grid.Row="2" Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center"
                                    Text="{Binding CurrentDay.SleepHours, StringFormat='{}{0:%h}h {0:%m}m', FallbackValue='__h __m'}"/>
                                <Label Grid.Row="3" VerticalOptions="Center" HorizontalOptions="Center"
                                    Text="Bed Time" />
                                <Label Grid.Row="3" Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center"
                                    Text="{Binding CurrentDay.BedTime, Converter={StaticResource TimeConverter}, FallbackValue='__:__ __'}"/>
                                <Label Grid.Row="4" VerticalOptions="Center" HorizontalOptions="Center"
                                    Text="Wake Time" />
                                <Label Grid.Row="4" Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center"
                                    Text="{Binding CurrentDay.WakeTime, Converter={StaticResource TimeConverter}, FallbackValue='__:__ __'}"/>
                            </Grid>
                        </Border>
                        <controls:CalendarView SelectedDate="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectedDate}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>