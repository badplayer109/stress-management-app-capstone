<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SchoolStressManagementApp.Controls"
             x:Class="SchoolStressManagementApp.Views.HydrationStatusPage"
             xmlns:viewModels="clr-namespace:SchoolStressManagementApp.ViewModels"
             Title="HydrationStatusPage"
             x:DataType="viewModels:HydrationStatusViewModel">
    <Grid>
        <Image
            Source="stress_management_background.png"
            Aspect="AspectFill"
            HorizontalOptions="Center"
            VerticalOptions="Center" />
        <ScrollView>
            <VerticalStackLayout Padding="30" Spacing="25">
                <controls:DefaultFrame />
                <controls:CircularProgressBar x:Name="HydrationStatusCircularBar"
                    Max="{Binding WaterIntakeOptimal}"
                    Min="{Binding WaterIntakeInit}"
                    Value="{Binding Value, Source={x:Reference WaterIntakeSlider}}"
                    Size="220"
                    Thickness="8"
                    ProgressColor="DeepSkyBlue"
                    ProgressLeftColor="LightSkyBlue"
                    TextColor="MidnightBlue" />
                <Grid BackgroundColor="AliceBlue" Padding="10" RowDefinitions="20, 20, 40">
                    <Label Text="Hydration Status"/>
                    <Label Grid.Row="1"
                        Text="{Binding Value, Source={x:Reference HydrationStatusCircularBar}, StringFormat='Water drank: {0:F0} cups'}" />
                    <Slider x:Name="WaterIntakeSlider" Grid.Row="2" Value="{Binding WaterIntake}" Maximum="16" Minimum="0" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>